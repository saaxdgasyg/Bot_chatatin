{
  "name": "finance-bot",
  "version": "1.0.0",
  "description": "Telegram Finance Bot – Record income & expenses via text, voice, or receipt photos. Powered by Gemini AI, Prisma, and PostgreSQL.",
  "main": "src/index.js",
  "scripts": {
    "start": "npx prisma db push && node src/index.js",
    "dev": "node src/index.js",
    "db:push": "npx prisma db push",
    "db:studio": "npx prisma studio",
    "postinstall": "npx prisma generate"
  },
  "keywords": [
    "telegram",
    "finance",
    "bot",
    "gemini",
    "prisma"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@google/genai": "^1.0.0",
    "@prisma/client": "^6.9.0",
    "dotenv": "^16.4.7",
    "telegraf": "^4.16.3"
  },
  "devDependencies": {
    "prisma": "^6.9.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
